# Environment for docker-compose / production
# Copy to .env and replace every placeholder with real, strong values.
# NEVER commit the real .env file.

NODE_ENV=production

# --- Database ---
POSTGRES_USER=samlogistic
# Use a long random password (e.g. `openssl rand -base64 24`)
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=samlogistic
# In docker-compose the host is the service name (postgres); locally use 127.0.0.1
DATABASE_URL=postgresql://samlogistic:CHANGE_ME_STRONG_DB_PASSWORD@postgres:5432/samlogistic?schema=public

# --- JWT (generate with `openssl rand -base64 48`) ---
JWT_SECRET=CHANGE_ME_ACCESS_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES=7d
JWT_RESET_PASSWORD_EXP_IN=1h

# --- App ---
PORT=6001
FRONTEND_URL=https://samlogistic.tn
MAIL_FROM=no-reply@samlogistic.tn
# Expose Swagger UI at /api only when explicitly enabled
SWAGGER_ENABLED=false

# --- Frontend ---
VITE_BASE_URL=https://api.samlogistic.tn
