# Backend environment (NestJS)
# Copy to .env and replace every placeholder with real, strong values.
# NEVER commit the real .env file (it is git-ignored).

NODE_ENV=production
PORT=6001

# --- Database ---
POSTGRES_USER=samlogistic
# Use a long random password (e.g. `openssl rand -base64 24`)
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=samlogistic
DATABASE_URL="postgresql://samlogistic:CHANGE_ME_STRONG_DB_PASSWORD@127.0.0.1:5432/samlogistic?schema=public"

# --- JWT (generate with `openssl rand -base64 48`) ---
JWT_SECRET=CHANGE_ME_ACCESS_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES=7d
JWT_RESET_PASSWORD_EXP_IN=1h

# --- App ---
FRONTEND_URL=https://samlogistic.tn
MAIL_FROM=no-reply@samlogistic.tn
# Expose Swagger UI at /api only when explicitly enabled (keep false in production)
SWAGGER_ENABLED=false
